# Secrets — never commit (includes DATABASE_URL, a direct Postgres password)
.env
youtube_token.pickle
youtube_client_secret.json

# Large/regenerable local output — audio, video, scripts are rebuilt by the
# pipeline and too large for git; once Supabase Storage is wired in, audio/
# script/thumbnail persist there instead.
output/
*.mp4
*.mp3
*.wav

# Local image/thumbnail assets (manually curated via Google Flow) — large
# binaries, not meant to live in git history.
images/
thumbnails/
assets/music/
assets/ambience/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store

# Local schedule/state cache (superseded by Supabase once migrated)
schedule.json
pipeline_status.json
logs/

# Kokoro TTS model files — large binaries (310MB+27MB), downloaded fresh by
# the GitHub Actions workflow each run (see .github/workflows/pipeline.yml).
# Locally this is a symlink to ~/kokoro-models/, not meant to live in git.
kokoro-models

# Standalone local test script — not part of the production pipeline.
test_deepseek_script.py
google_service_account.json
narava-google-service-account.json
